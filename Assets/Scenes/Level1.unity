  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1025294203}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ac9f96da2baf9e846be13c56d80883ae, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DrivingDialogueSystem
  dialogueText: {fileID: 250263048}
  speakerImage: {fileID: 823580497}
  protagonistSprite: {fileID: 2213816153390254764, guid: e064e3c95e79bfe4cab24be3954d9043, type: 3}
  friendSprite: {fileID: 8386798365106823877, guid: c0170643d64484d409c05dbf663993f9, type: 3}
  dialogueLines:
  - speaker: 1
    text: "\xBFEst\xE1s seguro de que vamos en la direcci\xF3n correcta?\r\n"
  - speaker: 0
    text: "S\xED. Todos los que lo han hecho siguen esta misma ruta.  \r\n"
  - speaker: 0
    text: "Recuerda estar atento a los alrededores; no pueden saber qu\xE9 estamos
      haciendo. "
  - speaker: 1
    text: "Est\xE1 bien\u2026 "
  - speaker: 0
    text: "\xBFQu\xE9 tienes?\r\n"
  - speaker: 1
    text: "Estoy preocupado. Esta situaci\xF3n me mantiene asustado, e-est\xE1s seguro
      q\u2026\r\n"
  - speaker: 0
    text: "Tranquilo, Octavio. Todo saldr\xE1 bien, llegaremos juntos y lo lograremos,
      \xBFOK?"
  - speaker: 1
    text: "Est\xE1 bien, s\xED. Hag\xE1moslo."
  - speaker: 1
    text: Traje esta Polaroid para hacer fotos de recuerdo; al menos me tranquiliza.
  - speaker: 0
    text: 'Bien.

'
